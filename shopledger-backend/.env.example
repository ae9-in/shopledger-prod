NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# PostgreSQL (recommended: direct vars, avoids URL-encoding issues)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=shopledger
PGUSER=postgres
PGPASSWORD=YOUR_REAL_PASSWORD_HERE

# Optional: if you prefer URL style, keep this commented unless password is URL-encoded
# DATABASE_URL=postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@127.0.0.1:5432/shopledger
